@echo off
chcp 65001 >nul
title AI 生图提示词生成器

echo ============================================
echo   AI 生图提示词生成器
echo ============================================
echo.
echo [调试] 当前目录: %cd%
echo [调试] 脚本路径: %~dp0
echo.

cd /d %~dp0

echo [调试] 切换后目录: %cd%
echo.

pause

:: 尝试定位 NODE.EXE
set "NODE_EXE="
if exist "C:\nvm4w\nodejs\node.exe" set "NODE_EXE=C:\nvm4w\nodejs\node.exe"
if exist "C:\Program Files\nodejs\node.exe" set "NODE_EXE=C:\Program Files\nodejs\node.exe"

if "%NODE_EXE%"=="" (
    for %%X in (node.exe) do set "NODE_EXE=%%~$PATH:X"
)

echo [调试] NODE_EXE = %NODE_EXE%
echo.

if "%NODE_EXE%"=="" (
    echo [错误] 未找到 Node.js
    echo 请安装 Node.js：https://nodejs.org/
    pause
    exit /b 1
)

echo [Node] %NODE_EXE%
"%NODE_EXE%" -v
echo.

pause

if not exist node_modules (
    echo [1/3] 首次运行，安装依赖...
    call npm install
    if errorlevel 1 (
        echo [错误] 依赖安装失败
        pause
        exit /b 1
    )
    echo [OK] 安装完成
    echo.
) else (
    echo [1/3] 依赖已就绪
)

if not exist .env.local (
    echo [2/3] 创建 .env.local...
    if exist .env.local.example (
        copy .env.local.example .env.local
        echo [提示] 请编辑 .env.local 填入 API Key
    ) else (
        echo [警告] 未找到 .env.local.example
    )
) else (
    echo [2/3] .env.local 已存在
)

echo.
echo [3/3] 启动服务...
echo ============================================
echo   服务启动后请访问: http://localhost:3000
echo   按 Ctrl+C 停止服务
echo ============================================
echo.

npm run dev

if errorlevel 1 (
    echo.
    echo [错误] 启动失败
    pause
    exit /b 1
)
